# Copy to backend/.env.deploy on the server and fill secrets.

# API and model settings
DASHSCOPE_API_KEY=sk-your-bailian-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=glm-5
BAILIAN_ENABLE_LLM=true
DASHSCOPE_TIMEOUT_SECONDS=120
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_EMBEDDING_CONCURRENCY=3

# Local model settings
LOCAL_MODEL_ENABLE=true
LOCAL_TRANSFORMER_ENABLE=false
LOCAL_EXACT_MATCH_ENABLE=false
LOCAL_REFERENCE_MODEL_ENABLE=true
LOCAL_SENTIMENT_MODEL=IDEA-CCNL/Erlangshen-Roberta-110M-Sentiment
LOCAL_ZERO_SHOT_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
LOCAL_MODEL_BATCH_SIZE=8
LOCAL_MODEL_MAX_DOCUMENTS=512
LOCAL_SENTIMENT_NEUTRAL_THRESHOLD=0.60
LOCAL_ZERO_SHOT_HYPOTHESIS_TEMPLATE=这段文本主要属于{}。

# API guards
CORS_ALLOW_ORIGINS=http://47.237.204.43
UPLOAD_MAX_FILE_BYTES=10485760
UPLOAD_MAX_ROWS=50000
UPLOAD_MAX_COLUMNS=128
UPLOAD_MAX_TEXT_LENGTH=20000
