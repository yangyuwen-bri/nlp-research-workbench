{
  "name": "nlp-workbench-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_TEST_WASM_DIR=$PWD/node_modules/@next/swc-wasm-nodejs next dev --webpack",
    "build": "NEXT_TEST_WASM_DIR=$PWD/node_modules/@next/swc-wasm-nodejs next build --webpack",
    "typecheck": "NEXT_TEST_WASM_DIR=$PWD/node_modules/@next/swc-wasm-nodejs next typegen && tsc --noEmit",
    "start": "NEXT_TEST_WASM_DIR=$PWD/node_modules/@next/swc-wasm-nodejs next start"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.2.4",
    "@next/swc-wasm-nodejs": "^16.2.4",
    "@next/swc-wasm-web": "^16.2.4"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "typescript": "5.8.3"
  }
}
